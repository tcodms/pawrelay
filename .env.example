# =============================================
# PawRelay .env.example
# 실제 값은 팀 채널에서 공유. 이 파일은 키 목록만 관리.
# =============================================

# --- Backend ---
# Docker PostgreSQL (config.py가 아래 4개 변수로 직접 URL을 조합함. DATABASE_URL은 사용 안 함)
POSTGRES_USER=your_db_user
POSTGRES_PASSWORD=your_db_password
POSTGRES_DB=your_db_name
POSTGRES_HOST=localhost
REDIS_URL=redis://localhost:6379

# JWT
# config.py의 secret_key 필드 → 환경변수 이름은 반드시 SECRET_KEY
SECRET_KEY=your_jwt_secret_here

# LLM
LLM_PROVIDER=openai
LLM_MAX_TOKENS=4096

# Session Backend (mock: 개발/테스트, redis: 프로덕션)
SESSION_BACKEND=mock
ANTHROPIC_API_KEY=your_anthropic_key_here
OPENAI_API_KEY=your_openai_key_here

# Kakao
KAKAO_REST_API_KEY=your_kakao_rest_api_key

# Email
EMAIL_PROVIDER=resend
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM=onboarding@resend.dev

# AWS S3
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_S3_BUCKET=pawrelay-images
AWS_REGION=ap-northeast-2

# Web Push (VAPID)
VAPID_PRIVATE_KEY=your_vapid_private_key
VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_EMAIL=mailto:admin@pawrelay.com

# 공공데이터포털
PUBLIC_DATA_API_KEY=your_public_data_key

# --- Frontend ---
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_KAKAO_MAP_API_KEY=your_kakao_map_key
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your_vapid_public_key

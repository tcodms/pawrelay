# =============================================
# PawRelay .env.example
# 실제 값은 팀 채널에서 공유. 이 파일은 키 목록만 관리.
# =============================================

# --- Backend ---
DATABASE_URL=postgresql://user:password@localhost:5432/pawrelay
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your_jwt_secret_here
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# LLM
LLM_PROVIDER=claude
ANTHROPIC_API_KEY=your_anthropic_key_here
OPENAI_API_KEY=your_openai_key_here

# Kakao
KAKAO_REST_API_KEY=your_kakao_rest_api_key

# Email
EMAIL_PROVIDER=sendgrid
SENDGRID_API_KEY=your_sendgrid_key_here
EMAIL_FROM=noreply@pawrelay.com

# AWS S3
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_S3_BUCKET=pawrelay-images
AWS_REGION=ap-northeast-2

# Web Push (VAPID)
VAPID_PRIVATE_KEY=your_vapid_private_key
VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_EMAIL=mailto:admin@pawrelay.com

# 공공데이터포털
PUBLIC_DATA_API_KEY=your_public_data_key

# --- Frontend ---
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_KAKAO_MAP_API_KEY=your_kakao_map_key
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your_vapid_public_key
